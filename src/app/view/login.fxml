<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="760.0" prefWidth="1180.0" styleClass="app-root" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controller.LoginController">
    <children>
        <VBox alignment="CENTER" maxWidth="520.0" spacing="18.0" styleClass="hero-card">
            <padding>
                <Insets top="36.0" right="36.0" bottom="36.0" left="36.0" />
            </padding>
            <Label styleClass="badge-pill" text="BLOX FRUIT FORMATIONS" />
            <Label styleClass="hero-title" text="Connexion" wrapText="true" />
            <Label styleClass="hero-subtitle" text="Connecte-toi pour acceder au tableau de bord administrateur." wrapText="true" />
            <TextField fx:id="fieldEmail" promptText="Email" styleClass="input-field" />
            <PasswordField fx:id="fieldMotDePasse" promptText="Mot de passe" styleClass="input-field" />
            <Button onAction="#connecter" styleClass="primary-button" text="Se connecter" />
            <HBox alignment="CENTER" spacing="10.0">
                <Label styleClass="status-label" text="Pas encore de compte ?" />
                <Button onAction="#ouvrirRegister" styleClass="link-button" text="S'inscrire" />
            </HBox>
            <Label fx:id="messageLabel" styleClass="status-label" wrapText="true" />
        </VBox>
    </children>
</StackPane>

