<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="820.0" prefWidth="1280.0" spacing="0.0" styleClass="app-root" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controller.SessionDetailController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-nav">
            <padding>
                <Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
            </padding>
            <Label styleClass="brand-label" text="Blox Fruit Formations" />
            <Button onAction="#retourSessions" styleClass="nav-button" text="Retour Sessions" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="navUserLabel" styleClass="nav-user" text="visiteur@local" />
            <Button onAction="#deconnecter" styleClass="secondary-button" text="Deconnexion" />
        </HBox>

        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="home-scroll" VBox.vgrow="ALWAYS">
            <content>
                <VBox alignment="TOP_LEFT" fillWidth="true" spacing="24.0" styleClass="content-wrap">
                    <padding>
                        <Insets top="30.0" right="28.0" bottom="28.0" left="28.0" />
                    </padding>
                    <VBox maxWidth="1280.0" spacing="24.0">
                        <Label fx:id="sessionTitleLabel" styleClass="hero-title" text="Détail Session" />

                        <VBox spacing="12.0" styleClass="hero-card">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                            <Label styleClass="section-title" text="Informations de la session" />
                            <HBox spacing="20.0">
                                <Label fx:id="formationLabel" text="Formation: " />
                                <Label fx:id="formateurLabel" text="Formateur: " />
                                <Label fx:id="dateLabel" text="Date: " />
                                <Label fx:id="salleLabel" text="Salle: " />
                            </HBox>
                        </VBox>

                        <VBox spacing="12.0" styleClass="hero-card">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                            <Label styleClass="section-title" text="Présences" />
                            <ListView fx:id="presencesListView" prefHeight="200.0" />
                            <HBox spacing="10.0">
                                <Label text="Taux de présence: " />
                                <Label fx:id="tauxPresenceLabel" text="0%" />
                            </HBox>
                        </VBox>

                        <VBox spacing="12.0" styleClass="hero-card">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                            <Label styleClass="section-title" text="Avis" />
                            <ListView fx:id="avisListView" prefHeight="200.0" />
                            <HBox spacing="10.0">
                                <Label text="Note moyenne: " />
                                <Label fx:id="moyenneAvisLabel" text="0/5" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>