<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="820.0" prefWidth="1280.0" spacing="0.0" styleClass="app-root" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controller.AuthViewController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-nav">
            <padding>
                <Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
            </padding>
            <Label styleClass="brand-label" text="Blox Fruit Formations" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#ouvrirAccueil" styleClass="nav-button nav-button-active" text="Accueil" />
            <Button onAction="#ouvrirLogin" styleClass="nav-button" text="Connexion" />
            <Button onAction="#ouvrirRegister" styleClass="nav-button" text="Inscription" />
        </HBox>

        <VBox alignment="CENTER" spacing="24.0" styleClass="content-wrap" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="32.0" right="28.0" bottom="32.0" left="28.0" />
            </padding>
            <VBox alignment="CENTER" maxWidth="980.0" spacing="16.0" styleClass="hero-card home-hero-card">
                <padding>
                    <Insets top="40.0" right="36.0" bottom="40.0" left="36.0" />
                </padding>
                <Label styleClass="badge-pill" text="BLOX FRUIT FORMATIONS" />
                <Label styleClass="hero-title" text="Bienvenue sur la plateforme de gestion des formations" wrapText="true" />
                <Label styleClass="hero-subtitle" text="Organise les sessions et suis les apprenants en quelques clics." wrapText="true" />
                <HBox alignment="CENTER" spacing="14.0">
                    <Button onAction="#ouvrirLogin" styleClass="primary-button" text="Se connecter" />
                    <Button onAction="#ouvrirRegister" styleClass="secondary-button" text="S'inscrire" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</VBox>

